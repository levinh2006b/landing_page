{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/,_N_T_/index"},"segmentPaths":["/_tree","/_full","/__PAGE__","/_index","/_head"]},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"preload\" href=\"/_next/static/media/797e433ab948586e-s.p.0.q-h669a_dqa.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"preload\" href=\"/_next/static/media/caa3a2e1cccd8315-s.p.16t1db8_9y2o~.woff2\" as=\"font\" crossorigin=\"\" type=\"font/woff2\"/><link rel=\"stylesheet\" href=\"/_next/static/chunks/02modu4~jdyt~.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/0hlda1~upve6~.js\"/><script src=\"/_next/static/chunks/0dgq26a5_oy.a.js\" async=\"\"></script><script src=\"/_next/static/chunks/0bogtdbh.dcu1.js\" async=\"\"></script><script src=\"/_next/static/chunks/0257pdz1-imal.js\" async=\"\"></script><script src=\"/_next/static/chunks/turbopack-15izot3a4m63x.js\" async=\"\"></script><script src=\"/_next/static/chunks/0-bhsf7fxsmej.js\" async=\"\"></script><script src=\"/_next/static/chunks/0d3shmwh5_nmn.js\" async=\"\"></script><script src=\"/_next/static/chunks/0q4ke72~4n9em.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>Ronan SAT - Master the SAT with Personalized, Data-Driven Practice</title><meta name=\"description\" content=\"Experience real test conditions, target your exact weaknesses, and achieve your dream score with our comprehensive SAT preparation platform. Full-length exams, sectional practice, and detailed explanations.\"/><script src=\"/_next/static/chunks/03~yq9q893hmn.js\" noModule=\"\"></script></head><body class=\"geist_a71539c9-module__T19VSG__variable geist_mono_8d43a2aa-module__8Li5zG__variable antialiased\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"min-h-screen bg-background font-sans\"><header class=\"sticky top-0 z-50 bg-background/80 backdrop-blur-md border-b border-border\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"flex justify-between items-center h-16\"><div class=\"flex items-center gap-2\"><h1 class=\"text-xl font-bold text-foreground tracking-tight\">Ronan SAT</h1></div><div class=\"flex items-center gap-4\"><a class=\"text-muted-foreground hover:text-foreground font-medium transition-colors\" href=\"https://learn.ronansat.com/auth\">Log in</a><a class=\"bg-primary hover:bg-blue-700 text-primary-foreground px-5 py-2.5 rounded-lg font-medium transition-all shadow-sm hover:shadow-md\" href=\"https://learn.ronansat.com/auth\">Sign up free</a></div></div></div></header><main><section class=\"relative overflow-hidden bg-gradient-to-b from-slate-50 to-white pt-20 pb-32\"><div class=\"absolute inset-0 overflow-hidden\"><div class=\"absolute -top-40 -right-40 w-80 h-80 bg-blue-100 rounded-full opacity-30 blur-3xl\"></div><div class=\"absolute top-60 -left-40 w-80 h-80 bg-slate-200 rounded-full opacity-40 blur-3xl\"></div></div><div class=\"relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid lg:grid-cols-2 gap-16 items-center\"><div style=\"opacity:0;transform:translateY(20px)\"><div class=\"inline-flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-full px-4 py-1.5 mb-6\"><span class=\"w-2 h-2 bg-blue-600 rounded-full animate-pulse\"></span><span class=\"text-sm font-medium text-blue-700\">Trusted by 10,000+ students</span></div><h1 class=\"text-5xl sm:text-6xl font-bold text-foreground tracking-tight leading-tight text-balance\">Master the SAT with<!-- --> <span class=\"text-primary\">Personalized, Data-Driven</span> <!-- -->Practice</h1><p class=\"mt-6 text-xl text-muted-foreground leading-relaxed max-w-xl\">Experience real test conditions, target your exact weaknesses, and achieve your dream score with our comprehensive SAT preparation platform.</p><div class=\"mt-10 flex flex-col sm:flex-row gap-4\"><a class=\"inline-flex items-center justify-center gap-2 bg-primary hover:bg-blue-700 text-primary-foreground px-8 py-4 rounded-xl text-lg font-semibold transition-all shadow-lg shadow-blue-500/25 hover:shadow-xl hover:shadow-blue-500/30\" href=\"/auth\">Start Free Trial<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-5 h-5\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a><a href=\"#features\" class=\"inline-flex items-center justify-center gap-2 bg-secondary hover:bg-slate-200 text-secondary-foreground px-8 py-4 rounded-xl text-lg font-semibold transition-all\">Explore Features</a></div><div class=\"mt-12 flex items-center gap-8\"><div class=\"flex items-center gap-2\"><div class=\"flex -space-x-2\"><div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-slate-200 to-slate-300 border-2 border-white flex items-center justify-center text-xs font-bold text-slate-600\">A</div><div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-slate-200 to-slate-300 border-2 border-white flex items-center justify-center text-xs font-bold text-slate-600\">B</div><div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-slate-200 to-slate-300 border-2 border-white flex items-center justify-center text-xs font-bold text-slate-600\">C</div><div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-slate-200 to-slate-300 border-2 border-white flex items-center justify-center text-xs font-bold text-slate-600\">D</div><div class=\"w-8 h-8 rounded-full bg-gradient-to-br from-slate-200 to-slate-300 border-2 border-white flex items-center justify-center text-xs font-bold text-slate-600\">E</div></div><span class=\"text-sm text-muted-foreground ml-2\"><span class=\"font-semibold text-foreground\">4.9/5</span> from 2,500+ reviews</span></div></div></div><div class=\"relative\" style=\"opacity:0;transform:scale(0.95)\"><div class=\"relative\"><div class=\"absolute inset-0 bg-gradient-to-r from-blue-500/20 to-blue-600/20 rounded-3xl blur-2xl transform scale-105\"></div><div class=\"relative bg-card border border-border rounded-2xl shadow-2xl overflow-hidden\"><div class=\"bg-slate-50 border-b border-border px-6 py-4 flex items-center justify-between\"><div class=\"flex items-center gap-3\"><div class=\"w-3 h-3 rounded-full bg-red-400\"></div><div class=\"w-3 h-3 rounded-full bg-yellow-400\"></div><div class=\"w-3 h-3 rounded-full bg-green-400\"></div></div><span class=\"text-sm font-medium text-muted-foreground\">Your Dashboard</span></div><div class=\"p-6\"><div class=\"text-center mb-8\"><p class=\"text-sm font-medium text-muted-foreground mb-2\">Your Projected Score</p><div class=\"text-7xl font-black text-primary\" style=\"opacity:0;transform:scale(0.8)\">1550+</div><div class=\"flex items-center justify-center gap-2 mt-2\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trending-up w-4 h-4 text-green-500\" aria-hidden=\"true\"><path d=\"M16 7h6v6\"></path><path d=\"m22 7-8.5 8.5-5-5L2 17\"></path></svg><span class=\"text-sm font-medium text-green-600\">+120 points improvement</span></div></div><div class=\"grid grid-cols-3 gap-4\"><div class=\"bg-slate-50 rounded-xl p-4 text-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock w-5 h-5 text-blue-600 mx-auto mb-2\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg><p class=\"text-2xl font-bold text-foreground\">24</p><p class=\"text-xs text-muted-foreground\">Tests Taken</p></div><div class=\"bg-slate-50 rounded-xl p-4 text-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-target w-5 h-5 text-blue-600 mx-auto mb-2\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"6\"></circle><circle cx=\"12\" cy=\"12\" r=\"2\"></circle></svg><p class=\"text-2xl font-bold text-foreground\">92%</p><p class=\"text-xs text-muted-foreground\">Accuracy</p></div><div class=\"bg-slate-50 rounded-xl p-4 text-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trending-up w-5 h-5 text-blue-600 mx-auto mb-2\" aria-hidden=\"true\"><path d=\"M16 7h6v6\"></path><path d=\"m22 7-8.5 8.5-5-5L2 17\"></path></svg><p class=\"text-2xl font-bold text-foreground\">Top 5%</p><p class=\"text-xs text-muted-foreground\">Percentile</p></div></div><div class=\"mt-6\"><div class=\"flex justify-between text-sm mb-2\"><span class=\"text-muted-foreground\">Progress to 1600</span><span class=\"font-semibold text-foreground\">97%</span></div><div class=\"h-2 bg-slate-100 rounded-full overflow-hidden\"><div class=\"h-full bg-gradient-to-r from-blue-500 to-blue-600 rounded-full\" style=\"width:0px\"></div></div></div></div></div></div></div></div></div></section><section id=\"features\" class=\"py-24 bg-white\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"text-center mb-16\" style=\"opacity:0;transform:translateY(20px)\"><h2 class=\"text-4xl font-bold text-foreground tracking-tight\">Two Powerful Testing Modes</h2><p class=\"mt-4 text-xl text-muted-foreground max-w-2xl mx-auto\">Whether you have 3 hours or 30 minutes, we have the perfect practice option for you.</p></div><div class=\"grid md:grid-cols-2 gap-6 mb-8\"><div class=\"group relative bg-card border border-border rounded-2xl p-8 hover:border-blue-200 hover:shadow-lg transition-all duration-300\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"inline-flex items-center justify-center w-14 h-14 rounded-xl mb-6 bg-blue-50 text-blue-600\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock w-7 h-7\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"M12 6v6l4 2\"></path></svg></div><h3 class=\"text-2xl font-bold text-foreground mb-3\">Authentic Full-Length Exams</h3><p class=\"text-muted-foreground leading-relaxed mb-6\">Experience exactly what test day feels like. Our full-length practice tests perfectly replicate the real Digital SAT interface, timing, and question formats.</p><div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-blue-50 text-blue-700 border border-blue-100\">3+ hours of focused practice per test</div><div class=\"absolute inset-0 rounded-2xl bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none\"></div></div><div class=\"group relative bg-card border border-border rounded-2xl p-8 hover:border-blue-200 hover:shadow-lg transition-all duration-300\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"inline-flex items-center justify-center w-14 h-14 rounded-xl mb-6 bg-slate-100 text-slate-700\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-target w-7 h-7\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"6\"></circle><circle cx=\"12\" cy=\"12\" r=\"2\"></circle></svg></div><h3 class=\"text-2xl font-bold text-foreground mb-3\">Targeted Sectional Practice</h3><p class=\"text-muted-foreground leading-relaxed mb-6\">Don&#x27;t have time for a full test? Take bite-sized, specific sections to drill down on your weak points and maximize your study efficiency.</p><div class=\"inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-medium bg-slate-100 text-slate-700 border border-slate-200\">Math, Reading &amp; Writing sections</div><div class=\"absolute inset-0 rounded-2xl bg-gradient-to-br from-blue-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none\"></div></div></div><div class=\"grid md:grid-cols-2 gap-6\"><div class=\"flex items-start gap-4 bg-slate-50 rounded-xl p-6\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex-shrink-0 w-12 h-12 rounded-lg bg-white border border-border flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chart-column w-6 h-6 text-blue-600\" aria-hidden=\"true\"><path d=\"M3 3v16a2 2 0 0 0 2 2h16\"></path><path d=\"M18 17V9\"></path><path d=\"M13 17V5\"></path><path d=\"M8 17v-3\"></path></svg></div><div><h4 class=\"font-semibold text-foreground mb-1\">Advanced Analytics</h4><p class=\"text-sm text-muted-foreground\">Track your progress with detailed performance breakdowns by topic, difficulty, and question type.</p></div></div><div class=\"flex items-start gap-4 bg-slate-50 rounded-xl p-6\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"flex-shrink-0 w-12 h-12 rounded-lg bg-white border border-border flex items-center justify-center\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-zap w-6 h-6 text-blue-600\" aria-hidden=\"true\"><path d=\"M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z\"></path></svg></div><div><h4 class=\"font-semibold text-foreground mb-1\">Adaptive Learning</h4><p class=\"text-sm text-muted-foreground\">Our system learns your patterns and recommends exactly what you need to practice next.</p></div></div></div></div></section><section class=\"py-24 bg-slate-50\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8\"><div class=\"grid lg:grid-cols-2 gap-16 items-center\"><div style=\"opacity:0;transform:translateX(-20px)\"><div class=\"inline-flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-full px-4 py-1.5 mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb w-4 h-4 text-blue-600\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><span class=\"text-sm font-medium text-blue-700\">Deep-Dive Review</span></div><h2 class=\"text-4xl font-bold text-foreground tracking-tight mb-6\">Understand Every Mistake</h2><p class=\"text-xl text-muted-foreground leading-relaxed mb-8\">Don&#x27;t just look at your score. Get step-by-step, highly detailed explanations for every single incorrect answer in both Full and Sectional modes.</p><ul class=\"space-y-4\"><li class=\"flex items-center gap-3\" style=\"opacity:0;transform:translateX(-10px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-blue-600 flex-shrink-0\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-foreground\">Detailed breakdown of each problem-solving step</span></li><li class=\"flex items-center gap-3\" style=\"opacity:0;transform:translateX(-10px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-blue-600 flex-shrink-0\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-foreground\">Common mistake patterns identified and explained</span></li><li class=\"flex items-center gap-3\" style=\"opacity:0;transform:translateX(-10px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-blue-600 flex-shrink-0\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-foreground\">Related concepts and strategies for similar questions</span></li><li class=\"flex items-center gap-3\" style=\"opacity:0;transform:translateX(-10px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-check w-5 h-5 text-blue-600 flex-shrink-0\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m9 12 2 2 4-4\"></path></svg><span class=\"text-foreground\">AI-powered chatbot for follow-up questions</span></li></ul></div><div style=\"opacity:0;transform:translateX(20px)\"><div class=\"relative\"><div class=\"absolute inset-0 bg-gradient-to-r from-blue-500/10 to-slate-500/10 rounded-3xl blur-2xl transform scale-105\"></div><div class=\"relative bg-card border border-border rounded-2xl shadow-xl overflow-hidden\"><div class=\"bg-white border-b border-border px-6 py-4\"><div class=\"flex items-center justify-between\"><span class=\"text-sm font-semibold text-foreground\">Question Review</span><span class=\"text-xs bg-red-50 text-red-600 px-2 py-1 rounded-full font-medium\">Incorrect</span></div></div><div class=\"grid md:grid-cols-2 divide-x divide-border\"><div class=\"p-6 bg-white\"><div class=\"flex items-center gap-2 mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-circle-x w-5 h-5 text-red-500\" aria-hidden=\"true\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><path d=\"m15 9-6 6\"></path><path d=\"m9 9 6 6\"></path></svg><span class=\"text-sm font-medium text-red-600\">Your Answer: B</span></div><div class=\"text-sm text-muted-foreground mb-4\"><span class=\"text-xs uppercase tracking-wide font-semibold text-slate-400 block mb-2\">Question</span><p class=\"text-foreground\">If 3x + 7 = 22, what is the value of 6x + 5?</p></div><div class=\"space-y-2\"><div class=\"p-3 rounded-lg text-sm border border-green-200 bg-green-50 text-green-700\">A) 35<span class=\"ml-2 text-xs font-medium\">(Correct)</span></div><div class=\"p-3 rounded-lg text-sm border border-red-200 bg-red-50 text-red-700\">B) 37<span class=\"ml-2 text-xs font-medium\">(Your answer)</span></div><div class=\"p-3 rounded-lg text-sm border border-slate-100 bg-slate-50 text-slate-600\">C) 39</div><div class=\"p-3 rounded-lg text-sm border border-slate-100 bg-slate-50 text-slate-600\">D) 41</div></div></div><div class=\"p-6 bg-slate-50\"><div class=\"flex items-center gap-2 mb-4\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-lightbulb w-5 h-5 text-blue-600\" aria-hidden=\"true\"><path d=\"M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5\"></path><path d=\"M9 18h6\"></path><path d=\"M10 22h4\"></path></svg><span class=\"text-sm font-semibold text-blue-700\">Step-by-Step Solution</span></div><div class=\"space-y-4 text-sm\"><div class=\"bg-white rounded-lg p-4 border border-slate-200\"><p class=\"font-medium text-foreground mb-2\">Step 1: Solve for x</p><p class=\"text-muted-foreground\">3x + 7 = 22<br/>3x = 22 - 7 = 15<br/>x = 5</p></div><div class=\"bg-white rounded-lg p-4 border border-slate-200\"><p class=\"font-medium text-foreground mb-2\">Step 2: Calculate 6x + 5</p><p class=\"text-muted-foreground\">6x + 5 = 6(5) + 5<br/>= 30 + 5 = <span class=\"font-bold text-blue-600\">35</span></p></div><div class=\"flex items-center gap-2 text-blue-600 font-medium cursor-pointer hover:text-blue-700 transition-colors\"><span>Ask AI for more help</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right w-4 h-4\" aria-hidden=\"true\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></div></div></div></div></div></div></div></div></div></section><section class=\"py-24 bg-white overflow-hidden\"><div class=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-12\"><div class=\"text-center\" style=\"opacity:0;transform:translateY(20px)\"><div class=\"inline-flex items-center gap-2 bg-blue-50 border border-blue-100 rounded-full px-4 py-1.5 mb-6\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-trophy w-4 h-4 text-blue-600\" aria-hidden=\"true\"><path d=\"M10 14.66v1.626a2 2 0 0 1-.976 1.696A5 5 0 0 0 7 21.978\"></path><path d=\"M14 14.66v1.626a2 2 0 0 0 .976 1.696A5 5 0 0 1 17 21.978\"></path><path d=\"M18 9h1.5a1 1 0 0 0 0-5H18\"></path><path d=\"M4 22h16\"></path><path d=\"M6 9a6 6 0 0 0 12 0V3a1 1 0 0 0-1-1H7a1 1 0 0 0-1 1z\"></path><path d=\"M6 9H4.5a1 1 0 0 1 0-5H6\"></path></svg><span class=\"text-sm font-medium text-blue-700\">Hall of Fame</span></div><h2 class=\"text-4xl font-bold text-foreground tracking-tight mb-4\">Join Our High Scorers</h2><p class=\"text-xl text-muted-foreground max-w-2xl mx-auto\">Thousands of students have achieved their dream scores with Ronan SAT. Here are some of their stories.</p></div></div><div class=\"relative\"><div class=\"absolute left-0 top-0 bottom-0 w-32 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none\"></div><div class=\"absolute right-0 top-0 bottom-0 w-32 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none\"></div><div class=\"flex animate-marquee\"><div class=\"flex-shrink-0 w-80 bg-card border border-border rounded-2xl p-6 mx-3 hover:border-blue-200 hover:shadow-lg transition-all duration-300\"><div class=\"flex items-start gap-4\"><div class=\"w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-blue-600 flex items-center justify-center text-white font-bold text-sm flex-shrink-0\">SC</div><div class=\"flex-1 min-w-0\"><div class=\"flex items-center justify-between mb-1\"><h4 class=\"font-semibold text-foreground truncate\">Sarah Chen</h4><div class=\"flex gap-0.5\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"roun